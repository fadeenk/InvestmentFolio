{
  "name": "ifolio",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "audit": "fallow audit",
    "check": "npm run format && npm run lint && npm run typecheck",
    "frontend": "npm --workspace=frontend run dev",
    "test": "npm --workspace=frontend run test",
    "test:frontend": "npm --workspace=frontend run test",
    "lint": "npm --workspace=frontend run lint",
    "format": "prettier --write .",
    "typecheck": "npm --workspace=frontend run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "fallow": "^2.88.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
