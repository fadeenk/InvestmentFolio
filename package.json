{
  "name": "folio",
  "private": true,
  "workspaces": ["frontend", "worker"],
  "scripts": {
    "dev:frontend": "npm --workspace=frontend run dev",
    "dev:worker":   "npm --workspace=worker run dev",
    "test":         "npm --workspace=frontend run test && npm --workspace=worker run test",
    "test:unit":    "npm --workspace=frontend run test:unit",
    "lint":         "eslint . --max-warnings=0",
    "lint:fix":     "eslint . --fix",
    "format":       "prettier --write .",
    "prepare":      "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  }
}